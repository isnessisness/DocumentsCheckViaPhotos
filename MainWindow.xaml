<Window x:Class="WpfOcrApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智能OCR批量提取与排版合并系统 (.NET 8)" Height="550" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="图片文件夹: " VerticalAlignment="Center" FontWeight="Bold" Width="80"/>
            <TextBox x:Name="TxtInputFolder" Width="400" Margin="0,0,10,0" IsReadOnly="True" VerticalContentAlignment="Center"/>
            <Button Content="选择目录" Width="80" Click="BtnSelectInput_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="输出文件夹: " VerticalAlignment="Center" FontWeight="Bold" Width="80"/>
            <TextBox x:Name="TxtOutputFolder" Width="400" Margin="0,0,10,0" IsReadOnly="True" VerticalContentAlignment="Center"/>
            <Button Content="选择目录" Width="80" Click="BtnSelectOutput_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="处理顺序: " VerticalAlignment="Center" FontWeight="Bold" Width="80"/>
            <ComboBox x:Name="CmbSort" Width="140" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,15,0">
                <ComboBoxItem Content="按文件名称 (A-Z)"/>
                <ComboBoxItem Content="按修改日期 (旧到新)"/>
            </ComboBox>

            <Button x:Name="BtnStart" Content="▶ 开始批量提取并合并" Width="160" Click="BtnStart_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>

            <ProgressBar x:Name="PbProgress" Width="200" Margin="15,0,0,0" Height="22" Minimum="0" Maximum="100"/>
            <TextBlock x:Name="TxtProgress" Text="0 %" VerticalAlignment="Center" Margin="10,0,0,0" Width="45" Foreground="#666" FontWeight="Bold"/>
        </StackPanel>

        <GroupBox Grid.Row="3" Header="运行日志与提取进度">
            <ListBox x:Name="LstLog" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F8F9FA"/>
        </GroupBox>
    </Grid>
</Window>